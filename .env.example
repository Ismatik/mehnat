# ============================================================
#  MEHNAT — общие переменные окружения
#  Скопируй в .env и заполни реальными значениями.
#  .env НЕ коммитим в git (см. .gitignore).
# ============================================================

# ---------- PostgreSQL (одна общая БД) ----------
POSTGRES_USER=mehnat
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=mehnat
# Хост/порт внутри docker-сети — менять не нужно
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Строка подключения для Go-API (собирается из значений выше)
DATABASE_URL=postgres://mehnat:change_me_strong_password@db:5432/mehnat?sslmode=disable

# ---------- Go API ----------
API_PORT=8080
# Секрет для подписи JWT админ-сессий. Сгенерируй: openssl rand -hex 32
JWT_SECRET=change_me_generate_with_openssl_rand_hex_32
# Время жизни access-токена админки
JWT_TTL=24h
# Режим: development | production
APP_ENV=production

# ---------- Первый суперадмин (сеется при старте API, если его ещё нет) ----------
# Логин общей админки пользователей. Пароль смените после первого входа.
SEED_ADMIN_EMAIL=admin@mehnat.tj
SEED_ADMIN_PASSWORD=change_me_admin_password

# Идентификаторы сайтов = префиксы таблиц в БД.
# Меняешь тут — меняешь везде согласованно.
SITE1_KEY=s1
SITE2_KEY=s2
SITE1_DOMAIN=mmashvarat.tj
SITE2_DOMAIN=a-khorijakor.tj

# ---------- Ссылки на ATS (встраиваются в сайты: кнопка сверху + QR снизу) ----------
SITE1_ATS_URL=http://185.177.2.94:3005/seeker
SITE2_ATS_URL=http://185.177.2.94:3005/seeker

# ---------- Front (Next.js) build-time ----------
# Публичный адрес API, который видит браузер пользователя.
# В проде — через nginx, поэтому просто /api
NEXT_PUBLIC_API_BASE=/api

# ---------- Бэкапы БД (сервис backup) ----------
# Сколько дней хранить дампы (ротация) и час ежедневного бэкапа (0–23, время контейнера/UTC).
BACKUP_KEEP_DAYS=14
BACKUP_HOUR=3

# ---------- Защита входа ----------
# После LOGIN_MAX_ATTEMPTS неудач в окне LOGIN_WINDOW_MINUTES — блок на LOGIN_LOCKOUT_MINUTES.
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=15
LOGIN_LOCKOUT_MINUTES=15

# ---------- Уведомления суперадмину (email) ----------
# Включить рассылку (true/false). Если false или SMTP не задан — просто не шлём.
NOTIFY_ENABLED=false
NOTIFY_EMAIL=superadmin@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
